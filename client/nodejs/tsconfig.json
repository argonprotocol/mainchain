{
  "compilerOptions": {
    "paths": {
      "@lodestar/params": ["node_modules/@lodestar/params/lib/index.d.ts"],
      "@lodestar/params/setPreset": ["node_modules/@lodestar/params/lib/setPreset.d.ts"],
      "@argonprotocol/mainchain": ["src/index.ts"],
      "@polkadot/api/augment": ["src/interfaces/augment-api.ts"],
      "@polkadot/types/lookup": ["src/interfaces/types-lookup.ts"],
      "@polkadot/types/augment": ["src/interfaces/augment-types.ts"],
      "@argonprotocol/mainchain/interfaces/*": ["src/interfaces/*/index.ts", "src/interfaces/*.ts"]
    },
    "target": "es2022",
    "module": "es2022",
    "declaration": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noImplicitReturns": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "rootDir": "./src",
    "sourceMap": true,
    "importHelpers": true,
    "skipDefaultLibCheck": true,
    "outDir": "./lib"
  },
  "include": [
    "./*.json",
    "src",
    "src/**/*.ts",
    // if you have augment-api.ts etc.
    "node_modules/@polkadot/**/*.d.ts"
  ],
  "exclude": ["lib", "browser", "**/localchain", "build/**/*", "node_modules", "target"]
}
