{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vitest/globals",
      "hardhat"
    ],
    "noEmit": true
  },
  "include": ["hardhat.config.ts", "script/**/*.ts", "test/**/*.ts"]
}
