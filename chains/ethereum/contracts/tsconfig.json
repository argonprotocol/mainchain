{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals", "hardhat"],
    "noEmit": true
  },
  "include": ["script/**/*.ts", "test/**/*.ts", "*.ts"]
}
