{
  "name": "@argonprotocol/mainchain",
  "version": "1.4.3",
  "description": "A client for accessing the Argon mainchain apis.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/argonprotocol/mainchain.git"
  },
  "author": "Argon Foundation",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/argonprotocol/mainchain/issues"
  },
  "homepage": "https://github.com/argonprotocol/mainchain#readme",
  "scripts": {
    "build": "yarn generate:defs && yarn generate:meta && node clean-build.js && yarn tsc",
    "generate:defs": "tsx node_modules/.bin/polkadot-types-from-defs --endpoint metadata.json --input ./src/interfaces --package @argonprotocol/mainchain/interfaces",
    "generate:meta": "tsx node_modules/.bin/polkadot-types-from-chain --endpoint metadata.json --output ./src/interfaces --package @argonprotocol/mainchain/interfaces --strict",
    "pretest": "yarn build && yarn workspace @argonprotocol/testing run build",
    "pretest:ci": "yarn build && yarn workspace @argonprotocol/testing run build",
    "test": "vitest --run --config vitest.config.ts",
    "tsc": "tsup",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "lib/",
    "browser/",
    "src/interfaces/"
  ],
  "type": "module",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "browser": {
        "types": "./browser/index.d.ts",
        "default": "./browser/index.js"
      },
      "import": "./lib/index.js",
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./interfaces/*": {
      "types": "./src/interfaces/*/index.ts"
    }
  },
  "dependencies": {
    "@chainsafe/persistent-merkle-tree": "1.2.5",
    "@ethereumjs/block": "^10.1.1",
    "@ethereumjs/mpt": "^10.1.1",
    "@lodestar/params": "1.42.0",
    "@lodestar/types": "1.42.0",
    "@polkadot/api": "^16.4.4",
    "@polkadot/api-base": "^16.4.4",
    "@polkadot/keyring": "^13.5.5",
    "@polkadot/rpc-core": "^16.4.4",
    "@polkadot/rpc-provider": "^16.4.4",
    "@polkadot/types": "^16.4.4",
    "@polkadot/types-codec": "^16.4.4",
    "@polkadot/util": "^13.5.5",
    "@polkadot/util-crypto": "^13.5.5",
    "bignumber.js": "^9.3.1",
    "bs58check": "^4.0.0",
    "camelcase-keys": "^9.1.3",
    "viem": "^2.38.5"
  },
  "devDependencies": {
    "@argonprotocol/testing": "1.4.3",
    "@polkadot/typegen": "^16.4.4",
    "@substrate/ss58-registry": "^1.51.0",
    "@types/node": "^20",
    "shx": "^0.4.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^4.0.5"
  },
  "packageManager": "yarn@4.1.0"
}
